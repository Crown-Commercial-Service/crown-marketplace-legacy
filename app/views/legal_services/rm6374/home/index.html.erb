<%= content_for :page_title, t('.heading') %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <h1 class="govuk-heading-xl">
      <%= t('.heading') %>
    </h1>

    <p class="govuk-body">
      <%= t('.use_this_service.para01') %>
    </p>

    <p class="govuk-body">
      <%= t('.use_this_service.para02') %>
    </p>

    <p class="govuk-body">
      <%= t('.use_this_service.para03_html', link: link_to(t('.use_this_service.legal_panel_for_government'), legal_panel_for_government_path), class: 'govuk-link govuk-link--no-visited-state') %>
    </p>

    <p class="govuk-body">
      <%= t('.use_this_service.para04_html') %>
    </p>

    <h2 class="govuk-heading-m govuk-!-margin-top-6 govuk-!-margin-bottom-2">
      <%= t('.use_this_service.before_heading') %>
    </h2>

    <p class="govuk-body">
      <%= t('.use_this_service.para05_html') %>
    </p>

    <%= govuk_button(t('shared.gateway.start_now'), href: journey_start_path(journey: LegalServices::Journey.journey_name), is_start_button: true, classes: 'govuk-!-margin-top-6 govuk-!-margin-bottom-9', attributes: { aria: { label: t('shared.gateway.start_now') } } ) %>

    <h3 class="govuk-heading-m govuk-!-margin-bottom-3">
      <%= t('.use_this_service.guidance_heading') %>
    </h3>

    <ul class="govuk-list govuk-list--bullet govuk-!-margin-left-2 govuk-!-margin-bottom-7">
      <li>
        <%= link_to(t('.wps_link.text'), t('.wps_link.url'), class: 'govuk-link') %>
      </li>
      <li>
        <%= link_to(t('.ojeu_link.text'), t('.ojeu_link.url_html'), class: 'govuk-link') %>
      </li>
    </ul>

  </div>
</div>

