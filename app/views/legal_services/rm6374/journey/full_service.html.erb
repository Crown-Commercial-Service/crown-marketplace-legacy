<%= add_optional_error_prefix_to_page_title(@journey.errors) %>
<%= content_for :page_title, t('.heading_1') %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= render partial: 'shared/error_summary', locals: { errors: @journey.errors } %>
    
    <h1 class="govuk-heading-xl govuk-!-margin-bottom-6">
      <%= t('.heading_1') %>
    </h1>
  </div>
</div>

<div class="govuk-grid-row">
  <%= form_with url: @form_path, method: :get, html: { specialvalidation: true, novalidate: true } do |f| %>
    <%= hidden_fields_for_previous_steps_and_responses(@journey) %>
    <%= hidden_field_tag(:sector, @journey.current_step.sector) %>

    <div class="govuk-grid-column-two-thirds" id="selection-checkboxes">
      <%= govuk_checkboxes(
        :service_numbers,
        @journey.current_step.full_service.map do |service|

          {
            value: service.number,
            label: {
              text: service.name
            },
            attributes: {
              id: "service_#{service.number}"
            }
          }
        end,
        model: @journey.current_step,
        fieldset: {
          legend: {
            text: t('.question'),
            classes: 'govuk-fieldset__legend--m'
          }
        }
      ) %>
    </div>

    <div class="govuk-grid-column-one-third">
      <%= render partial: 'shared/basket', locals: { form: f, data_text_1:  t('.full_service_selected'), data_text_2: t('.no_full_service_selected'), data_text_3: t('.specialism_selected'), search_text: t('.search_full_services') } %>
    </div>
  <% end %>
</div>