<%= add_optional_error_prefix_to_page_title(@journey.errors) %>
<%= content_for :page_title, t('.question') %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= render partial: 'shared/error_summary', locals: { errors: @journey.errors } %>

    <span class="govuk-caption-xl">
      <%= lot_full_name(@journey.current_step.lot) %>
    </span>

    <%= form_with url: @form_path, method: :get, html: { specialvalidation: true, novalidate: true } do |f| %>
      <%= hidden_fields_for_previous_steps_and_responses(@journey) %>
      <%= hidden_field_tag(:lot_number, params[:lot_number]) %>
      
      <%= govuk_radios(
        :call_off_mechanism,
        %w[award_with_direct_competition rapid_award quotation_process].map do |option|
          {
            value: option,
            label: {
              text: t(".answer.#{option}")
            }
          }
        end,
        model: @journey.current_step,
        fieldset: {
          legend: {
            text: t('.question'),
            classes: 'govuk-fieldset__legend--m',
            is_page_heading: true
          }
        },
        hint: {
          text: t('.hint')
        }
      ) %>

      <%= govuk_button(t('common.continue', default: 'Continue'), form: f, classes: 'govuk-!-padding-left-7 govuk-!-padding-right-7', attributes: { id: 'submit', name: t('common.continue', default: 'Continue') }) %>
    <% end %>
  </div>
</div>

