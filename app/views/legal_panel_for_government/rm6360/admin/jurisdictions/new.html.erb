<%= content_for :page_title, t('.heading') %>

<% admin_breadcrumbs(
  { text: t('shared.admin.suppliers.index.heading'), href: suppliers_index_path },
  { text: t('shared.admin.lot_data.index.heading'), href: supplier_lot_data_index_path(@supplier_framework) },
  { text: t('shared.admin.lot_data.show.heading.heading', section: t("shared.admin.lot_data.show.heading.#{@section}")), href: supplier_lot_data_show_path(@supplier_framework, @lot.number_as_slug, @section) },
  { text: t('legal_panel_for_government.rm6360.admin.jurisdictions.edit.heading'), href: legal_panel_for_government_rm6360_admin_jurisdictions_edit_path(@supplier_framework, @lot.number_as_slug) },
  { text: t('.heading') }
)%>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-three-quarters">
    <%= form_with url: legal_panel_for_government_rm6360_admin_jurisdictions_create_path, method: :post, html: { novalidate: true } do |f| %>

      <%= rates_error_summary %>

      <%= govuk_fieldset(
        legend: {
          text: t('.heading'),
          classes: 'govuk-fieldset__legend--l govuk-!-margin-bottom-6',
          is_page_heading: true,
          caption: {
            text: capture do
              concat(tag.span(@supplier_framework.supplier_name, class: 'govuk-caption-m'))
              concat(tag.span(t("shared.admin.lot_data.show.heading.caption", lot_number: @lot.number, lot_name: @lot.name), class: 'govuk-caption-l'))
            end,
          }
        }
      ) do %>

        <div class="govuk-summary-card">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title">
              <%= t('legal_panel_for_government.rm6360.admin.lot_data.show.rates.supplier_rates_for', country: @supplier_framework_lot_jurisdiction.jurisdiction.name) %>
            </h2>
          </div>
          <div class="govuk-summary-card__content">
            <div class="section-list-group">
              <%= govuk_table(
                *rates_form_table_headers_and_rows(@supplier_framework_lot_rates),
                first_cell_is_header: true,
                classes: 'ccs-rates-table'
              ) %>
            </div>
          </div>
        </div>

        <div class="govuk-button-group">
          <%= govuk_button(t('.add_rates'), form: f, attributes: { aria: { label: t('.add_rates') } }) %>
          <%= govuk_button(t('.cancel'), href: legal_panel_for_government_rm6360_admin_jurisdictions_edit_path(@supplier_framework, @lot.number_as_slug), classes: 'govuk-button--secondary', attributes: { aria: { label: t('.cancel') } }) %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
